---
import Base from '../../layouts/Base.astro';

const projects = await Astro.glob('../../content/projects/*.md');
const sorted = projects.sort((a, b) => {
  const order = { 'active': 0, 'shipped': 1, 'paused': 2 };
  return (order[a.frontmatter.status] ?? 3) - (order[b.frontmatter.status] ?? 3);
});
---

<Base title="Projects">
  <div class="page-header">
    <h1>Projects</h1>
    <p>Things I'm building, have built, or am thinking about building.</p>
  </div>

  {sorted.length === 0 && (
    <p class="empty">No projects yet. Go to <a href="/admin">/admin</a> to add your first one.</p>
  )}

  <div class="projects">
    {sorted.map(project => (
      <a href={project.url} class="project-card">
        <div class="card-header">
          <h2>{project.frontmatter.title}</h2>
          <span class={`status status-${project.frontmatter.status}`}>{project.frontmatter.status}</span>
        </div>
        <p class="description">{project.frontmatter.description}</p>
        {project.frontmatter.tags && (
          <div class="tags">
            {project.frontmatter.tags.map(tag => <span class="tag">{tag}</span>)}
          </div>
        )}
        {project.frontmatter.url && (
          <span class="ext-link">visit project →</span>
        )}
      </a>
    ))}
  </div>
</Base>

<style>
  .page-header { margin-bottom: 3rem; }
  .page-header h1 {
    font-size: 2.2rem;
    font-style: italic;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .page-header p { font-family: var(--sans); color: var(--ink-muted); font-size: 0.95rem; }

  .projects { display: flex; flex-direction: column; gap: 1px; }
  .project-card {
    display: block;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--cream-dark);
    transition: 0.15s;
  }
  .project-card:first-child { border-top: 1px solid var(--cream-dark); }
  .project-card:hover .card-header h2 { color: var(--accent); }

  .card-header {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.5rem;
  }
  .card-header h2 { font-size: 1.1rem; font-weight: 500; transition: 0.15s; }

  .status {
    font-family: var(--sans);
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 2px 8px;
    border-radius: 100px;
  }
  .status-active { background: var(--green-soft); color: var(--green); }
  .status-shipped { background: var(--accent-soft); color: var(--brown); }
  .status-paused { background: var(--cream-dark); color: var(--ink-hint); }

  .description {
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--ink-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
    max-width: 520px;
  }

  .tags { display: flex; gap: 0.4rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
  .tag {
    font-family: var(--sans);
    font-size: 0.72rem;
    color: var(--ink-muted);
    background: var(--cream-dark);
    padding: 2px 8px;
    border-radius: 100px;
  }

  .ext-link {
    font-family: var(--sans);
    font-size: 0.82rem;
    color: var(--accent);
  }

  .empty { font-family: var(--sans); font-size: 0.9rem; color: var(--ink-hint); font-style: italic; }
  .empty a { color: var(--accent); text-decoration: underline; }
</style>
